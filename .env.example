# Copy secrets into .env.local (gitignored). Relay runs fully without the optional keys,
# using a built-in deterministic generator; add a key to upgrade to live LLM output.

# --- Database (required) ---------------------------------------------------
# Postgres connection string. Locally this points at the docker-compose Postgres.
# On Vercel, the Postgres/Neon integration provides this; for the smoothest first
# deploy use the DIRECT / unpooled connection string.
DATABASE_URL="postgresql://relay:relay@localhost:5432/relay?schema=public"

# --- Optional --------------------------------------------------------------
# Enables live AI generation via OpenRouter. Without it, Relay uses a
# deterministic offline generator so everything still works.
OPENROUTER_API_KEY=""

# Comma-separated model fallback chain for OpenRouter. Defaults to:
# google/gemini-flash-1.5, deepseek/deepseek-chat, qwen/qwen-2.5-72b-instruct
# OPENROUTER_MODELS=""

# Shared secret to verify GitHub webhook payloads (X-Hub-Signature-256).
# GITHUB_WEBHOOK_SECRET=""

# Set to 1 to wipe and re-seed demo data on the next build/seed run.
# SEED_FORCE=""
