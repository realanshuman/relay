# Copy secret values into .env.local (gitignored). Relay runs fully without them,
# using a built-in deterministic generator; add a key to upgrade to live LLM output.

# Local SQLite database (already set in committed .env)
DATABASE_URL="file:./dev.db"

# Optional: enables live AI generation via OpenRouter.
# Without it, Relay uses a deterministic, offline generator so everything still works.
OPENROUTER_API_KEY=""

# Optional: comma-separated model fallback chain for OpenRouter.
# Defaults to: google/gemini-flash-1.5, deepseek/deepseek-chat, qwen/qwen-2.5-72b-instruct
# OPENROUTER_MODELS=""

# Optional: shared secret to verify GitHub webhook payloads (X-Hub-Signature-256)
# GITHUB_WEBHOOK_SECRET=""
