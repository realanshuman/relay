# Copy secrets into .env.local (gitignored). Relay runs fully without the optional keys,
# using a built-in deterministic generator; add a key to upgrade to live LLM output.

# --- Database (required) ---------------------------------------------------
# Postgres connection string. Locally this points at the docker-compose Postgres.
# On Vercel, the Postgres/Neon integration provides this; for the smoothest first
# deploy use the DIRECT / unpooled connection string.
DATABASE_URL="postgresql://relay:relay@localhost:5432/relay?schema=public"

# --- Auth (Better Auth, required) ------------------------------------------
# Signing secret. Generate one: `openssl rand -hex 32`
BETTER_AUTH_SECRET=""
# Public base URL of the app (used for auth callbacks & reset links).
BETTER_AUTH_URL="http://localhost:3000"

# --- Social login (optional) -----------------------------------------------
# Buttons appear automatically when a provider's pair is set. Callback URL is
# <BETTER_AUTH_URL>/api/auth/callback/github (and /google).
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# --- Optional --------------------------------------------------------------
# Enables live AI generation via OpenRouter. Without it, Relay uses a
# deterministic offline generator so everything still works.
OPENROUTER_API_KEY=""

# Comma-separated model fallback chain for OpenRouter. Defaults to:
# google/gemini-flash-1.5, deepseek/deepseek-chat, qwen/qwen-2.5-72b-instruct
# OPENROUTER_MODELS=""

# Shared secret to verify GitHub webhook payloads (X-Hub-Signature-256).
# GITHUB_WEBHOOK_SECRET=""

# Transactional email (password-reset links, subscriber emails). Without a key,
# password reset still works in "demo mode" by showing the link on screen.
# Get a key at https://resend.com
# RESEND_API_KEY=""
# EMAIL_FROM="Relay <noreply@tryrelay.run>"

# Absolute app URL — used to build reset/webhook links. On Vercel this is inferred
# from request headers, but set it if you use a custom domain.
# NEXT_PUBLIC_APP_URL="https://tryrelay.run"

# Set to 1 to wipe and re-seed demo data on the next build/seed run.
# SEED_FORCE=""
